# GEMINI API Keys - Support multiple keys for automatic fallback
# Get keys from: https://aistudio.google.com/app/apikey
# Add multiple keys to automatically rotate if one expires or hits quota limits

# Recommended: Multiple API keys for automatic fallback (numbered approach)
GEMINI_API_KEY_1="YOUR_FIRST_API_KEY_HERE"
GEMINI_API_KEY_2="YOUR_SECOND_API_KEY_HERE"
GEMINI_API_KEY_3="YOUR_THIRD_API_KEY_HERE"

# Fallback: Single API key (used if numbered keys aren't found)
GEMINI_API_KEY="YOUR_API_KEY_HERE"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Configuration
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
