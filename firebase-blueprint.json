{
  "entities": {
    "Macro": {
      "title": "Macro",
      "description": "A saved macro or canned response.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "summary": { "type": "string" },
        "response": { "type": "string" },
        "dateAdded": { "type": "string" },
        "userId": { "type": "string" },
        "isFavorite": { "type": "boolean" }
      },
      "required": ["id", "summary", "response", "dateAdded", "userId"]
    },
    "LinkItem": {
      "title": "LinkItem",
      "description": "A saved link.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "url": { "type": "string" },
        "description": { "type": "string" },
        "dateAdded": { "type": "string" },
        "userId": { "type": "string" },
        "isFavorite": { "type": "boolean" }
      },
      "required": ["id", "url", "description", "dateAdded", "userId"]
    },
    "Template": {
      "title": "Template",
      "description": "A saved template.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "fields": {
          "type": "array",
          "items": { "type": "object" }
        },
        "dateAdded": { "type": "number" },
        "userId": { "type": "string" },
        "isFavorite": { "type": "boolean" }
      },
      "required": ["id", "name", "fields", "dateAdded", "userId"]
    },
    "UpdateItem": {
      "title": "UpdateItem",
      "description": "A saved update.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "severity": { "type": "string" },
        "link": { "type": "string" },
        "imageUrl": { "type": "string" },
        "dateAdded": { "type": "string" },
        "userId": { "type": "string" }
      },
      "required": ["id", "title", "content", "severity", "dateAdded", "userId"]
    },
    "Workflow": {
      "title": "Workflow",
      "description": "An interactive step-by-step decision tree or ticket maker.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "dateAdded": { "type": "string" },
        "userId": { "type": "string" },
        "isFavorite": { "type": "boolean" },
        "nodes": {
          "type": "array",
          "items": { "type": "object" }
        },
        "startingNodeId": { "type": "string" }
      },
      "required": ["id", "name", "dateAdded", "userId", "nodes"]
    }
  },
  "firestore": {
    "/macros/{macroId}": {
      "schema": { "$ref": "#/entities/Macro" },
      "description": "Macros collection"
    },
    "/links/{linkId}": {
      "schema": { "$ref": "#/entities/LinkItem" },
      "description": "Links collection"
    },
    "/templates/{templateId}": {
      "schema": { "$ref": "#/entities/Template" },
      "description": "Templates collection"
    },
    "/updates/{updateId}": {
      "schema": { "$ref": "#/entities/UpdateItem" },
      "description": "Updates collection"
    },
    "/workflows/{workflowId}": {
      "schema": { "$ref": "#/entities/Workflow" },
      "description": "Workflows collection"
    }
  }
}
